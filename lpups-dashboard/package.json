{
  "name": "lpups-dashboard",
  "version": "1.1.0",
  "description": "LPUPS Case Panel — 7\" Dashboard",
  "main": "./out/main/index.js",
  "scripts": {
    "dev":           "electron-vite dev",
    "build":         "electron-vite build",
    "start":         "electron-vite preview",
    "dist":          "electron-vite build && electron-builder --win",
    "dist:portable": "electron-vite build && electron-builder --win portable"
  },
  "build": {
    "appId":       "com.lpups.casepanel",
    "productName": "LPUPS Dashboard",
    "copyright":   "Copyright 2025 LPUPS",
    "directories": {
      "output":         "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "scripts", "to": "scripts", "filter": ["**/*.ps1"] }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon":                    "resources/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick":                          false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut":             true,
      "createStartMenuShortcut":           true,
      "shortcutName":                      "LPUPS Dashboard",
      "runAfterFinish":                    true
    }
  },
  "dependencies": {
    "react":     "^18.3.1",
    "react-dom": "^18.3.1",
    "ws":        "^8.18.0"
  },
  "devDependencies": {
    "@types/node":          "^22.0.0",
    "@types/react":         "^18.3.3",
    "@types/react-dom":     "^18.3.0",
    "@types/ws":            "^8.5.13",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer":         "^10.4.20",
    "electron":             "^35.0.0",
    "electron-builder":     "^26.0.0",
    "electron-vite":        "^3.0.0",
    "postcss":              "^8.5.0",
    "tailwindcss":          "^3.4.17",
    "typescript":           "^5.7.0"
  }
}
