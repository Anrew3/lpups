{
  "compilerOptions": {
    "composite":        true,
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "target":           "ES2022",
    "jsx":              "react-jsx",
    "strict":           true,
    "skipLibCheck":     true,
    "outDir":           "out/renderer"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
