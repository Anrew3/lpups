    "dev":   "tsup src/plugin.ts --format cjs --outDir bin --no-splitting --watch"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
