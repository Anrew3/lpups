{
  "name": "com.lpups.casepanel",
  "version": "1.0.0",
  "description": "LattePanda UPS Case Panel for Stream Deck",
  "main": "bin/plugin.js",
  "scripts": {
    "prebuild": "node scripts/generate-icons.js",
    "build":    "tsup src/plugin.ts --format cjs --outDir bin --no-splitting --minify",
    "watch":    "tsup src/plugin.ts --format cjs --outDir bin --no-splitting --watch",
    "dev":      "tsup src/plugin.ts --format cjs --outDir bin --no-splitting --watch"
  },
  "dependencies": {
    "@elgato/streamdeck": "1.4.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
