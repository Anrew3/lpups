{
  "name": "com.lpups.casepanel",
  "version": "1.0.0",
  "description": "LattePanda UPS Case Panel for Stream Deck",
  "main": "bin/plugin.js",
  "scripts": {
    "build": "tsup src/plugin.ts --format cjs --outDir bin --no-splitting --minify",
