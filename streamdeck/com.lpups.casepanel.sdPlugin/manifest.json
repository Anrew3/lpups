{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Name": "LPUPS Case Panel",
  "Version": "1.1.0.0",
  "Author": "LPUPS",
  "URL": "https://github.com/Anrew3/lpups",
  "Description": "LattePanda UPS monitoring and control — battery status, power draw, network toggle, and system diagnostics.",
  "Category": "LPUPS",
  "CategoryIcon": "imgs/plugin/category-icon",
  "CodePath": "bin/plugin.js",
  "Icon": "imgs/plugin/marketplace",
  "UUID": "com.lpups.casepanel",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "Actions": [
    {
      "Name": "Battery Status",
      "UUID": "com.lpups.casepanel.battery",
      "Icon": "imgs/actions/battery/icon",
      "Tooltip": "B1 (18650 UPS) and B2 (12V LiON pack) capacity, state, and charging indicator.",
      "Controllers": ["Keypad"],
      "DisableAutomaticStates": true,
      "UserTitleEnabled": false,
      "SupportedInMultiActions": false,
      "States": [
        {
          "Image": "imgs/actions/battery/key"
        }
      ]
    },
    {
      "Name": "Power and Runtime",
      "UUID": "com.lpups.casepanel.power",
      "Icon": "imgs/actions/power/icon",
      "Tooltip": "Live power draw in Watts and estimated minutes remaining on the 12V pack.",
      "Controllers": ["Keypad"],
      "DisableAutomaticStates": true,
      "UserTitleEnabled": false,
      "SupportedInMultiActions": false,
      "States": [
        {
          "Image": "imgs/actions/power/key"
        }
      ]
    },
    {
      "Name": "Network Mode",
      "UUID": "com.lpups.casepanel.network",
      "Icon": "imgs/actions/network/icon",
      "Tooltip": "Toggle between WiFi-first and Cellular-first routing priority. Both adapters stay active.",
      "Controllers": ["Keypad"],
      "DisableAutomaticStates": true,
      "UserTitleEnabled": false,
      "SupportedInMultiActions": false,
      "States": [
        {
          "Image": "imgs/actions/network/key"
        }
      ]
    },
    {
      "Name": "UPS Events",
      "UUID": "com.lpups.casepanel.events",
      "Icon": "imgs/actions/events/icon",
      "Tooltip": "Last event from the Arduino UPS — charger connected/disconnected, kick-in, shutdown trigger.",
      "Controllers": ["Keypad"],
      "DisableAutomaticStates": true,
      "UserTitleEnabled": false,
      "SupportedInMultiActions": false,
      "States": [
        {
          "Image": "imgs/actions/events/key"
        }
      ]
    },
    {
      "Name": "System Control",
      "UUID": "com.lpups.casepanel.system",
      "Icon": "imgs/actions/system/icon",
      "Tooltip": "Tap to initiate shutdown (with 4-second confirm). Hold 2.5 seconds to restart.",
      "Controllers": ["Keypad"],
      "DisableAutomaticStates": true,
      "UserTitleEnabled": false,
      "SupportedInMultiActions": false,
      "States": [
        {
          "Image": "imgs/actions/system/key"
        }
      ]
    },
    {
      "Name": "Diagnostics",
      "UUID": "com.lpups.casepanel.diagnostics",
      "Icon": "imgs/actions/diagnostics/icon",
      "Tooltip": "Run 15 system sanity checks. Shows pass/warn/fail summary. Tap result to open detailed report.",
      "Controllers": ["Keypad"],
      "DisableAutomaticStates": true,
      "UserTitleEnabled": false,
      "SupportedInMultiActions": false,
      "States": [
        {
          "Image": "imgs/actions/diagnostics/key"
        }
      ]
    }
  ]
}
